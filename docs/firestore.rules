rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    // Only the rating aggregate fields are being changed (used after a review is posted).
    function onlyRatingChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rating', 'ratingCount']);
    }

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
    }

    match /admins/{uid} { allow read: if isOwner(uid) || isAdmin(); allow write: if isAdmin(); }

    match /stores/{id} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid
                    && request.resource.data.approved == false;
      allow update: if isAdmin()
                    || (isOwner(resource.data.ownerUid) && request.resource.data.approved == resource.data.approved)
                    || (isSignedIn() && onlyRatingChanged());
      allow delete: if isAdmin();
    }
    match /services/{id} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid
                    && request.resource.data.approved == false;
      allow update: if isAdmin()
                    || (isOwner(resource.data.ownerUid) && request.resource.data.approved == resource.data.approved)
                    || (isSignedIn() && onlyRatingChanged());
      allow delete: if isAdmin();
    }

    match /products/{id} { allow read: if true; allow write: if isSignedIn(); }

    // Company master catalog: signed-in sellers read & pick; only admin edits.
    match /catalog/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }

    // Service offerings (provider picks from catalog, admin approves).
    match /serviceOfferings/{id} {
      allow read: if true;
      allow create: if isOwner(request.resource.data.ownerUid);
      allow update, delete: if isAdmin() || isOwner(resource.data.ownerUid);
    }
    match /banners/{id} { allow read: if true; allow write: if isAdmin(); }
    match /categories/{id} { allow read: if true; allow write: if isAdmin(); }
    match /growItems/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }

    match /orders/{id} {
      allow read: if isSignedIn();
      allow create: if isOwner(request.resource.data.customerUid);
      allow update: if isSignedIn();
    }
    match /serviceRequests/{id} {
      allow read: if isSignedIn();
      allow create: if isOwner(request.resource.data.customerUid);
      allow update: if isSignedIn();
    }
    match /bookings/{id} {
      allow read: if isSignedIn();
      allow create: if isOwner(request.resource.data.customerUid);
      allow update: if isSignedIn();
    }
    match /appointments/{id} {
      allow read: if isSignedIn();
      allow create: if isOwner(request.resource.data.customerUid);
      allow update: if isSignedIn();
    }

    match /notifications/{id} {
      allow read, update: if isOwner(resource.data.toUid);
      allow create: if isSignedIn();
    }

    // App settings (e.g. global banner design): public read, admin write.
    match /settings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Billing plans (activation + monthly per category): readable by signed-in, admin-only edit.
    match /plans/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }

    // Per-seller billing: a seller reads their own; only admin writes (records payments).
    match /billing/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if isAdmin();
    }

    // Payment history records (activation + monthly): owner reads own, admin writes.
    match /payments/{id} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid);
      allow write: if isAdmin();
    }

    // Reviews: anyone can read; a signed-in customer can post their own.
    match /reviews/{id} {
      allow read: if true;
      allow create: if isOwner(request.resource.data.customerUid);
      allow delete: if isAdmin();
    }

    // Chat: signed-in participants can read/write threads and their messages.
    match /chatThreads/{id} {
      allow read, create, update: if isSignedIn();
      match /messages/{mid} {
        allow read, create: if isSignedIn();
      }
    }
  }
}
